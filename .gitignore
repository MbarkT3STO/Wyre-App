# ============================================================
# Root .gitignore — covers DesktopApp, AndroidApp, and CI
# ============================================================


# ── OS ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini


# ── Editors & IDEs ───────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~


# ── Node / npm ────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz


# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo


# ── Vite ─────────────────────────────────────────────────────
.vite/


# ── Build outputs ─────────────────────────────────────────────
dist/
dist-electron/
out/
build/


# ── Logs ─────────────────────────────────────────────────────
logs/
*.log


# ── Environment & secrets ─────────────────────────────────────
.env
.env.local
.env.*.local
*.env


# ── Testing ───────────────────────────────────────────────────
coverage/
.vitest/


# ── Electron — release artifacts ──────────────────────────────
DesktopApp/release/
*.dmg
*.dmg.blockmap
*.exe
*.msi
*.AppImage
*.deb
*.rpm
*.snap
*.pkg


# ── Android — Gradle build outputs ────────────────────────────
AndroidApp/android/.gradle/
AndroidApp/android/app/build/
AndroidApp/android/build/
AndroidApp/android/local.properties
AndroidApp/android/app/release/
AndroidApp/android/.idea/
AndroidApp/android/captures/
AndroidApp/android/app/*.ap_
AndroidApp/android/app/*.apk


# ── Android — Capacitor generated assets ──────────────────────
# (regenerated by `npx cap sync`, do not commit)
AndroidApp/android/app/src/main/assets/public/


# ── Android — signing keystores (NEVER commit these) ──────────
*.jks
*.keystore
*.p12


# ── Android — local SDK path ──────────────────────────────────
local.properties


# ── Capacitor ─────────────────────────────────────────────────
# Keep android/ folder but ignore generated/build files above


# ── Misc ──────────────────────────────────────────────────────
*.local
*.tmp
*.temp
*.bak
*.orig
